// File: src/test/resources/FML/WorkflowDemo.fml/WorkflowDemo.fml
// Drop this in the fml-mcp-server test resources to test execute_workflow.

import java.lang.String;
import java.lang.Double;

@URI("http://fmlmcp.test/FML/WorkflowDemo.fml")
@Version("0.1")
public model WorkflowDemo {

    // ── Top-level properties ──────────────────────────────────────────────
    Double lastResult;
    String lastMessage;

    // ── Top-level ActionSchemes (these are what execute_workflow targets) ─

    /**
     * A simple no-arg workflow that sets a known result.
     * Useful as a smoke test for execute_workflow.
     */
    public String hello() {
        lastMessage = "Hello from WorkflowDemo!";
        return lastMessage;
    }

    /**
     * A workflow that accepts two numbers and returns their sum.
     * Tests argument passing through execute_workflow.
     */
    public Double add(Double a, Double b) {
        lastResult = a + b;
        return lastResult;
    }

    /**
     * A workflow that creates several Calc instances and returns a summary.
     * Tests that top-level behaviours can interact with concept instances.
     */
    public String runBatch() {
        Calc c1 = new Calc(10.0, 3.0);
        Calc c2 = new Calc(20.0, 4.0);
        Double sum1 = c1.add();
        Double sum2 = c2.add();
        lastMessage = "Batch: " + sum1 + " and " + sum2;
        return lastMessage;
    }

    // ── Concept ───────────────────────────────────────────────────────────

    public concept Calc {
        Double a;
        Double b;

        create(Double a, Double b) {
            this.a = parameters.a;
            this.b = parameters.b;
        }

        public Double add() {
            return a + b;
        }

        public Double multiply() {
            return a * b;
        }

        delete() {}
    }
}
